  "datasets": [
    {
      "id": "deepvk/ru-HNP",
      "license": "Apache-2.0",
      "usage": ["sts", "paraphrase", "hard_negative_finetune", "synthetic"],
      "splits": ["train"],
      "coverage_tags": ["hard_negative", "paraphrase", "negation", "numeric_logic", "entity_swap"],
      "contaminates_rumteb_tasks": [],
      "notes": "Synthetic GPT-3.5 hard non-paraphrase dataset. STS-v5 increases its contribution relative to STS-v3 to test whether stronger hard-negative supervision improves clean STS22."
    },
    {
      "id": "merionum/ru_paraphraser",
      "license": "MIT",
      "usage": ["sts", "paraphrase", "multitask"],
      "splits": ["train"],
      "coverage_tags": ["sts", "paraphrase", "news_headlines"],
      "contaminates_rumteb_tasks": ["RUParaPhraserSTS"],
      "notes": "Exact ruMTEB dataset path overlap for RUParaPhraserSTS; not for clean STS22."
    },
    {
      "id": "ai-forever/ru-stsbenchmark-sts",
      "license": "CC-BY-SA-4.0",
      "usage": ["sts", "pair_score", "multitask"],
      "splits": ["train"],
      "coverage_tags": ["sts", "graded_similarity"],
      "contaminates_rumteb_tasks": ["RuSTSBenchmarkSTS"],
      "notes": "Exact ruMTEB dataset path overlap for RuSTSBenchmarkSTS; not for clean STS22."
    },
    {
      "id": "ai-forever/rubq-retrieval",
      "license": "CC-BY-SA-4.0",
      "usage": ["retrieval", "hard_negative_finetune"],
      "splits": ["train"],
      "coverage_tags": ["retrieval"],
      "contaminates_rumteb_tasks": ["RuBQRetrieval"],
      "notes": "Exact ruMTEB dataset path overlap."
    },
    {
      "id": "ai-forever/ru-scibench-grnti-classification",
      "license": "MIT",
      "usage": ["classification", "multitask"],
      "splits": ["train"],
