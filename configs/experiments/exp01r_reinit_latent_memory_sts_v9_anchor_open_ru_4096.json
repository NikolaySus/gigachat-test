{
  "name": "exp01r_reinit_latent_memory_sts_v9_anchor_open_ru_4096",
  "description": "Fair 1R-STS stage 2: initialize from reinit broad 1R checkpoint and run STS-v9 style STS/hard-negative training with anchoring to the fair 1R latent state.",
  "model_name": "ai-sage/Giga-Embeddings-instruct",
  "local_files_only": true,
  "attn_implementation": "flash_attention_2",
  "latent_architecture": "original_latent_attention",
  "initial_latent_checkpoint": "experiments/exp01_reinit_fair/checkpoints/open_ru_1r_4096/latest.pt",
  "freeze_llm": true,
  "reinit_latent": false,
  "data_path": "data/contrastive/open_ru_sts_v6_train.jsonl",
  "output_dir": "experiments/exp01_reinit_fair/checkpoints/open_ru_sts_v9_anchor_4096",
  "max_length": 4096,
  "batch_size": 12,
  "learning_rate": 1e-5,
  "weight_decay": 0.01,
  "temperature": 0.03,
  "pair_score_loss_weight": 1.0,
  "log_every": 50,
  "save_every": 2250,
  "seed": 13,
  "retention": {
    "parameter_anchor_weight": 10.0
  },
  "stages": [
    {
      "name": "soft_pair_scores_anchor_to_1r",
      "data_path": "data/contrastive/open_ru_sts_v6_train.jsonl",
      "objectives": ["pair_score"],
      "max_steps": 450,
      "batch_size": 12,
      "pair_score_loss_weight": 0.5,
      "temperature": 0.02,
      "parameter_anchor_weight": 10.0
    },
    {
      "name": "hard_contrastive_b4_anchor_to_1r",
      "data_path": "data/contrastive/open_ru_sts_v6_train.jsonl",
      "objectives": ["contrastive"],
      "max_steps": 1800,
      "batch_size": 4,
      "temperature": 0.03,
      "parameter_anchor_weight": 10.0
    }
  ]
}
