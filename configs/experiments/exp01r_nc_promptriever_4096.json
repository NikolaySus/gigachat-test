{
  "name": "exp01r_nc_promptriever_4096",
  "description": "Fair 1R-NC per-source ablation: reinitialize original latent-attention block and train on clean filtered ru-promptriever only. Uses batch 2 because every record has 5 negatives; 8000 steps keeps 16000-record exposure.",
  "model_name": "ai-sage/Giga-Embeddings-instruct",
  "local_files_only": true,
  "attn_implementation": "flash_attention_2",
  "latent_architecture": "original_latent_attention",
  "initial_latent_checkpoint": null,
  "freeze_llm": true,
  "reinit_latent": true,
  "data_path": "data/contrastive/open_ru_1r_nc_promptriever.jsonl",
  "output_dir": "experiments/exp01_reinit_fair/checkpoints/open_ru_1r_nc_promptriever_4096",
  "max_length": 4096,
  "batch_size": 2,
  "learning_rate": 1e-5,
  "weight_decay": 0.01,
  "temperature": 0.02,
  "max_steps": 8000,
  "log_every": 50,
  "save_every": 8000,
  "seed": 13
}
