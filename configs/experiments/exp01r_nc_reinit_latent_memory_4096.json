{
  "name": "exp01r_nc_reinit_latent_memory_4096",
  "description": "Fair 1R-NC: reinitialize original latent-attention block and train on clean no-known-ruMTEB-contamination sources with equal 1600-record exposure per source. Long-document sources use batch 4 with 400 steps to avoid OOM at full 4096 context.",
  "model_name": "ai-sage/Giga-Embeddings-instruct",
  "local_files_only": true,
  "attn_implementation": "flash_attention_2",
  "latent_architecture": "original_latent_attention",
  "initial_latent_checkpoint": null,
  "freeze_llm": true,
  "reinit_latent": true,
  "data_path": "data/contrastive/open_ru_1r_nc_train.jsonl",
  "output_dir": "experiments/exp01_reinit_fair/checkpoints/open_ru_1r_nc_4096",
  "max_length": 4096,
  "batch_size": 8,
  "learning_rate": 1e-5,
  "weight_decay": 0.01,
  "temperature": 0.02,
  "max_steps": 1400,
  "log_every": 50,
  "save_every": 1000,
  "seed": 13,
  "stages": [
    {
      "name": "ru_hnp_200",
      "data_path": "data/contrastive/open_ru_1r_nc_deepvk_ru_hnp.jsonl",
      "max_steps": 200,
      "batch_size": 8
    },
    {
      "name": "geracl_200",
      "data_path": "data/contrastive/open_ru_1r_nc_geracl.jsonl",
      "max_steps": 200,
      "batch_size": 8
    },
    {
      "name": "promptriever_200",
      "data_path": "data/contrastive/open_ru_1r_nc_promptriever.jsonl",
      "max_steps": 200,
      "batch_size": 8
    },
    {
      "name": "grounded_rag_1600_records",
      "data_path": "data/contrastive/open_ru_1r_nc_grounded_rag_v2.jsonl",
      "max_steps": 400,
      "batch_size": 4
    },
    {
      "name": "habr_qa_sbs_hard_1600_records",
      "data_path": "data/contrastive/open_ru_1r_nc_habr_qa_sbs_hard.jsonl",
      "max_steps": 400,
      "batch_size": 4
    }
  ]
}
