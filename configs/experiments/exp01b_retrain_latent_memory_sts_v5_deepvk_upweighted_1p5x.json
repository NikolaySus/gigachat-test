{
  "name": "exp01b_retrain_latent_memory_sts_v5_deepvk_upweighted_1p5x",
  "description": "STS-v5: STS-v3-style clean run with deepvk/ru-HNP increased from 3000 to 4500 records and overall training steps increased 1.5x. Hard stage remains batch 4 to avoid known OOM at larger hard batches.",
  "model_name": "ai-sage/Giga-Embeddings-instruct",
  "local_files_only": true,
  "attn_implementation": "flash_attention_2",
  "latent_architecture": "original_latent_attention",
  "freeze_llm": true,
  "reinit_latent": false,
  "data_path": "data/contrastive/open_ru_sts_v5_train.jsonl",
  "output_dir": "experiments/exp01_original_latent_memory/checkpoints/open_ru_sts_v5_deepvk_upweighted_1p5x",
  "max_length": 4096,
  "batch_size": 12,
  "learning_rate": 1e-5,
  "weight_decay": 0.01,
  "temperature": 0.03,
  "pair_score_loss_weight": 1.0,
  "log_every": 10,
  "save_every": 2250,
  "seed": 13,
  "stages": [
    {
      "name": "soft_pair_scores_1p5x",
      "data_path": "data/contrastive/open_ru_sts_v5_train.jsonl",
      "objectives": ["pair_score"],
      "max_steps": 450,
      "batch_size": 12,
      "pair_score_loss_weight": 0.5,
      "temperature": 0.02
    },
    {
      "name": "hard_contrastive_b4_1p5x",
      "data_path": "data/contrastive/open_ru_sts_v5_train.jsonl",
      "objectives": ["contrastive"],
      "max_steps": 1800,
      "batch_size": 4,
      "temperature": 0.03
    }
  ]
}
