{
  "name": "exp01b_retrain_latent_memory_sts_v13b_promptriever_retrieval_only",
  "description": "STS-v13b: initialize from STS-v12 1600 one-pass and apply a RuPromptriever standard retrieval-only recovery stage.",
  "model_name": "ai-sage/Giga-Embeddings-instruct",
  "local_files_only": true,
  "attn_implementation": "flash_attention_2",
  "latent_architecture": "original_latent_attention",
  "initial_latent_checkpoint": "experiments/exp01_original_latent_memory/checkpoints/open_ru_sts_v12_v9_targeted_recovery_1600_1pass/latest.pt",
  "freeze_llm": true,
  "reinit_latent": false,
  "data_path": "data/contrastive/open_ru_sts_v13_recovery_candidates.jsonl",
  "output_dir": "experiments/exp01_original_latent_memory/checkpoints/open_ru_sts_v13b_promptriever_retrieval_only",
  "max_length": 4096,
  "batch_size": 4,
  "learning_rate": 1e-6,
  "weight_decay": 0.01,
  "temperature": 0.02,
  "pair_score_loss_weight": 1.0,
  "log_every": 10,
  "save_every": 750,
  "seed": 13,
  "retention": {
    "parameter_anchor_weight": 20.0
  },
  "stages": [
    {
      "name": "promptriever_retrieval_only",
      "data_path": "data/contrastive/open_ru_sts_v13_recovery_candidates.jsonl",
      "objectives": ["contrastive"],
      "sources": ["Vladimirlv/ru-promptriever-dataset:standard"],
      "max_steps": 750,
      "batch_size": 4,
      "temperature": 0.02,
      "parameter_anchor_weight": 20.0
    }
  ]
}
