{
  "name": "exp01b_retrain_latent_memory_sts_v3",
  "description": "Experiment 1b STS-v3: controlled staged ablation with smaller ru-HNP weight, soft pair-score warmup, then hard contrastive negatives.",
  "model_name": "ai-sage/Giga-Embeddings-instruct",
  "local_files_only": true,
  "attn_implementation": "flash_attention_2",
  "latent_architecture": "original_latent_attention",
  "freeze_llm": true,
  "reinit_latent": false,
  "data_path": "data/contrastive/open_ru_sts_v3_train.jsonl",
  "output_dir": "experiments/exp01_original_latent_memory/checkpoints/open_ru_sts_v3",
  "max_length": 4096,
  "batch_size": 12,
  "learning_rate": 1e-5,
  "weight_decay": 0.01,
  "temperature": 0.02,
  "pair_score_loss_weight": 1.0,
  "log_every": 10,
  "save_every": 100,
  "seed": 13,
  "stages": [
    {
      "name": "soft_pair_scores",
      "data_path": "data/contrastive/open_ru_sts_v3_train.jsonl",
      "objectives": ["pair_score"],
      "max_steps": 300,
      "batch_size": 12,
      "pair_score_loss_weight": 0.5
    },
    {
      "name": "hard_contrastive",
      "data_path": "data/contrastive/open_ru_sts_v3_train.jsonl",
      "objectives": ["contrastive"],
      "max_steps": 700,
      "batch_size": 12,
      "temperature": 0.03
    }
  ]
}
