{
  "name": "exp01b_retrain_latent_memory_sts_v2",
  "description": "Experiment 1b rerun: original latent-memory block trained on STS-focused open Russian mix with ru-HNP hard negatives and graded pair-score records.",
  "model_name": "ai-sage/Giga-Embeddings-instruct",
  "local_files_only": true,
  "attn_implementation": "flash_attention_2",
  "latent_architecture": "original_latent_attention",
  "freeze_llm": true,
  "reinit_latent": false,
  "data_path": "data/contrastive/open_ru_sts_v2_train.jsonl",
  "output_dir": "experiments/exp01_original_latent_memory/checkpoints/open_ru_sts_v2",
  "max_length": 4096,
  "batch_size": 12,
  "learning_rate": 1e-5,
  "weight_decay": 0.01,
  "temperature": 0.02,
  "pair_score_loss_weight": 1.0,
  "max_steps": 1000,
  "log_every": 10,
  "save_every": 100,
  "seed": 13
}
